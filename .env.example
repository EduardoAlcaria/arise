# Copy this file to .env and fill in the values
# Generate JWT_SECRET:        openssl rand -base64 32
# Generate ENCRYPTION_SECRET: openssl rand -base64 32

POSTGRES_PASSWORD=
RABBITMQ_PASSWORD=
JWT_SECRET=
ENCRYPTION_SECRET=

# Optional — comma-separated origins (default: localhost:3000 and localhost:5173)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional — Postgres user (default: automation_user)
# POSTGRES_USER=automation_user

# Optional — RabbitMQ user (default: automation)
# RABBITMQ_USER=automation

# Optional — logo.dev token for service logos in CI/CD page
# VITE_LOGO_DEV_TOKEN=
